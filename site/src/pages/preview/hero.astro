---
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head><meta charset="utf-8" /><title>preview: hero 3d</title></head>
  <body style="margin:0;background:#07090e;">
    <div style="width:560px;height:560px;margin:20px;">
      <canvas id="c" style="width:100%;height:100%;display:block;"></canvas>
    </div>
    <script>
      import { mountHero3D } from '../../lib/hero3d';
      const c = document.getElementById('c');
      const q = new URLSearchParams(location.search);
      const num = (k: string, d: number) => (q.has(k) ? Number(q.get(k)) : d);
      mountHero3D(c as HTMLCanvasElement, `${import.meta.env.BASE_URL}cube3.glb`.replace(/([^:])\/\/+/g, '$1/'), {
        rotX: num('rx', 0.5),
        rotY: num('ry', -0.66),
        dist: num('d', 7.2),
        fov: num('fov', 30),
      });
    </script>
  </body>
</html>
