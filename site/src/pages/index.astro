---
import Base from '../layouts/Base.astro';
import LiveShowcase from '../components/LiveShowcase.astro';
import CodeTabs from '../components/CodeTabs.astro';
import {
  vanillaSnippet,
  reactSnippet,
  vueSnippet,
  svelteSnippet,
  headlessSnippet,
} from '../lib/snippets';

const frameworkTabs = [
  { id: 'react', label: 'React', lang: 'tsx', code: reactSnippet },
  { id: 'vue', label: 'Vue', lang: 'vue', code: vueSnippet },
  { id: 'svelte', label: 'Svelte', lang: 'svelte', code: svelteSnippet },
  { id: 'vanilla', label: 'Vanilla', lang: 'ts', code: vanillaSnippet },
];
---
<Base>
  <!-- ── Hero ──────────────────────────────────────────────────── -->
  <header class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Rust · WebAssembly · Canvas 2D</p>
        <h1 class="hero-title">
          Pixel-faithful <span class="grad">Office</span> documents,<br />
          rendered in the browser.
        </h1>
        <p class="hero-lead">
          <code>@silurus/ooxml</code> parses <strong>.docx</strong>, <strong>.xlsx</strong> and
          <strong>.pptx</strong> with a Rust/WASM engine and paints them to a Canvas — no server,
          no MS Office, no iframe. The closest thing to PowerPoint/Word/Excel rendering on the web.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="https://www.npmjs.com/package/@silurus/ooxml">npm install @silurus/ooxml</a>
          <a class="btn btn-ghost" href="https://github.com/yukiyokotani/office-open-xml-viewer">GitHub ↗</a>
        </div>
      </div>
      <div class="hero-art">
        <div class="hero-art-glow"></div>
        <canvas id="hero3d" aria-hidden="true"></canvas>
      </div>
    </div>
  </header>

  <script>
    import { mountHero3D } from '../lib/hero3d';
    const c = document.getElementById('hero3d');
    if (c) {
      const url = `${import.meta.env.BASE_URL}cube3.glb`.replace(/([^:])\/\/+/g, '$1/');
      mountHero3D(c as HTMLCanvasElement, url);
    }
  </script>

  <!-- ── Live showcase (validation: real PPTX viewer) ──────────── -->
  <section class="section" id="showcase">
    <div class="wrap" data-reveal>
      <p class="eyebrow">Live in this page</p>
      <h2 class="section-title">Not a screenshot — the real renderer.</h2>
      <p class="section-lead">
        Each tab below is the actual library running a real document in your browser right now —
        Rust/WASM parse, Canvas paint. Switch formats, step through pages, scroll the sheet.
      </p>
      <LiveShowcase />
    </div>
  </section>

  <!-- ── Code / framework integration ──────────────────────────── -->
  <section class="section section-alt" id="code">
    <div class="wrap" data-reveal>
      <p class="eyebrow">Framework-agnostic</p>
      <h2 class="section-title">Drop it into your stack.</h2>
      <p class="section-lead">
        The viewers are plain TypeScript classes — no framework runtime, no peer deps. Hand one a
        <code>&lt;canvas&gt;</code> (or a container, for Excel) and call <code>load()</code>. Here's the
        same PowerPoint viewer in four flavours; Word and Excel follow the identical shape.
      </p>
      <div class="code-wrap">
        <CodeTabs tabs={frameworkTabs} filename="Deck.tsx" />
      </div>

      <div class="headless">
        <div class="headless-copy">
          <h3 class="headless-title">Or compose your own UI.</h3>
          <p class="headless-lead">
            Each format also ships a <strong>headless engine</strong>
            (<code>PptxPresentation</code> / <code>DocxDocument</code> / <code>XlsxWorkbook</code>)
            that renders into any canvas you supply. Build thumbnail grids, scroll views, or
            master–detail panes — you own the chrome, the library owns the pixels.
          </p>
        </div>
        <div class="code-wrap">
          <CodeTabs tabs={[{ id: 'headless', label: 'thumbnails.ts', lang: 'ts', code: headlessSnippet }]} />
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    padding: 96px 0 84px;
    border-bottom: 1px solid var(--border);
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 32px;
    align-items: center;
  }
  .hero-art {
    position: relative;
    aspect-ratio: 1 / 1;
    min-height: 0;
  }
  .hero-art canvas {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity 0.8s ease;
    cursor: grab;
  }
  .hero-art canvas.ready { opacity: 1; }
  .hero-art-glow {
    position: absolute;
    inset: 8% 8% 8% 8%;
    background: radial-gradient(closest-side, rgba(94, 234, 212, 0.16), rgba(129, 140, 248, 0.1) 55%, transparent 75%);
    filter: blur(8px);
  }
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-art { max-width: 420px; margin: 8px auto 0; width: 100%; }
  }
  .hero-title {
    font-size: clamp(34px, 6vw, 68px);
    font-weight: 800;
    margin: 18px 0 0;
    letter-spacing: -0.03em;
  }
  .grad {
    background: linear-gradient(120deg, var(--accent), var(--accent-2) 60%, var(--accent-3));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lead {
    margin: 22px 0 0;
    max-width: 62ch;
    font-size: 18px;
    color: var(--text-dim);
  }
  .hero-lead code, .hero-lead strong { color: var(--text); }
  .hero-lead code { font-family: var(--mono); font-size: 0.92em; }
  .hero-cta { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }

  .section-alt { background: linear-gradient(180deg, transparent, rgba(12, 15, 23, 0.6)); }
  .section-lead code {
    font-family: var(--mono);
    font-size: 0.9em;
    color: var(--text);
    background: var(--bg-elev-2);
    padding: 1px 6px;
    border-radius: 5px;
  }
  .code-wrap { margin-top: 28px; }

  .headless {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 28px;
    align-items: center;
  }
  .headless-title { font-size: 24px; font-weight: 700; }
  .headless-lead {
    margin-top: 12px;
    color: var(--text-dim);
    font-size: 16px;
  }
  .headless-lead code, .headless-lead strong { color: var(--text); }
  .headless-lead code { font-family: var(--mono); font-size: 0.9em; }
  @media (max-width: 860px) {
    .headless { grid-template-columns: 1fr; }
  }
</style>
