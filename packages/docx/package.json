{
  "name": "@silurus/ooxml-docx",
  "version": "0.71.0",
  "description": "DOCX parser and Canvas renderer (part of @silurus/ooxml)",
  "license": "MIT",
  "author": "Yuki Yokotani <silurus.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiyokotani/office-open-xml-viewer.git",
    "directory": "packages/docx"
  },
  "homepage": "https://github.com/yukiyokotani/office-open-xml-viewer#readme",
  "bugs": {
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./wasm": "./src/wasm/docx_parser.js",
    "./wasm-binary": "./src/wasm/docx_parser_bg.wasm"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --build && vite build",
    "preview": "vite preview",
    "wasm": "cd parser && wasm-pack build --target web --out-dir ../src/wasm && node ../../../scripts/append-wasm-reinit.mjs ../src/wasm/docx_parser.js",
    "typecheck": "tsc --noEmit",
    "vrt": "playwright test --config playwright.config.ts",
    "vrt:worker": "playwright test --config playwright.config.ts worker-equivalence"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@silurus/ooxml-core": "workspace:*",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^6.3.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
