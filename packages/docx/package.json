{
  "name": "@silurus/ooxml-docx",
  "private": true,
  "version": "0.72.2",
  "description": "DOCX parser and Canvas renderer (internal workspace package of @silurus/ooxml)",
  "license": "MIT",
  "author": "Yuki Yokotani <silurus.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiyokotani/office-open-xml-viewer.git",
    "directory": "packages/docx"
  },
  "homepage": "https://github.com/yukiyokotani/office-open-xml-viewer#readme",
  "bugs": {
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./wasm": "./src/wasm/docx_parser.js",
    "./wasm-binary": "./src/wasm/docx_parser_bg.wasm"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --build && vite build && tsc -p tsconfig.declarations.json",
    "build:ci": "vite build && tsc -p tsconfig.declarations.json",
    "preview": "vite preview",
    "wasm": "cd parser && wasm-pack build --target web --out-dir ../src/wasm && node ../../../scripts/append-wasm-reinit.mjs ../src/wasm/docx_parser.js",
    "typecheck": "tsc --noEmit",
    "vrt": "playwright test --config playwright.config.ts --project=chrome",
    "vrt:worker": "playwright test --config playwright.config.ts worker-equivalence",
    "conformance": "playwright test --config playwright.config.ts conformance.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "vite": "^6.3.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "dependencies": {
    "@silurus/ooxml-core": "workspace:*"
  }
}
